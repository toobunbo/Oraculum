def TestOneInput(data):
    driver = Driver(data)
    if driver.should_skip():
        return
{% if oracle_approach == "recorded_call" %}
    with driver.mock_context() as recorder:
        try:
            driver.act()
        except RuntimeError:
            raise
        except Exception:
            return
        driver.assert_recorded_call(recorder)
{% elif oracle_approach == "return_value" %}
    try:
        result = driver.act()
    except RuntimeError:
        raise
    except Exception:
        return
    driver.assert_return_value(result)
{% elif oracle_approach == "filesystem_state" %}
    before = driver.snapshot_filesystem()
    try:
        driver.act()
    except RuntimeError:
        raise
    except Exception:
        return
    after = driver.snapshot_filesystem()
    driver.assert_filesystem_state(before, after)
    driver.cleanup_filesystem(before, after)
{% endif %}


