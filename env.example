# =============================================================================
# LLM Provider Selection
# =============================================================================

# Provider: openai | anthropic | ollama
# LLM_PROVIDER=openai

# Model name:
#   OpenAI / compatible:  deepseek-chat, deepseek-v3-1-250821, gpt-4o
#   Anthropic:            claude-opus-4-6, claude-sonnet-4-6
#   Ollama:               llama3.2, qwen3:latest
# LLM_MODEL=deepseek-chat

# =============================================================================
# Option 1: DeepSeek via shopaikey.com (recommended for experiment reproduction)
# =============================================================================
# LLM_PROVIDER=openai
# LLM_MODEL=deepseek-v3-1-250821
# OPENAI_API_KEY=sk-your-deepseek-api-key
# OPENAI_API_BASE=https://api.shopaikey.com/v1

# =============================================================================
# Option 2: OpenAI
# =============================================================================
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-your-openai-api-key

# =============================================================================
# Option 3: Anthropic (Claude)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =============================================================================
# Option 4: Ollama (local)
# =============================================================================
# OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# Option 5: Ollama Cloud (multi-key rotation)
# =============================================================================
# OLLAMA_API_KEYS=key1,key2,key3
# OLLAMA_API_BASE=https://ollama.com
